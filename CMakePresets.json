{
  "version": 3,
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug (No Optimization)",
      "description": "Debug build with debug symbols and no optimization for safe debugging.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release (High Performance)",
      "description": "Release build with maximum optimization flags (-O3) for real simulations.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "displayName": "Build Debug"
    },
    {
      "name": "release",
      "configurePreset": "release",
      "displayName": "Build Release"
    }
  ]
}